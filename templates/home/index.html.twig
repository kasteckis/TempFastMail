{% extends 'base.html.twig' %}

{% block title %}Temp Fast Mail - Disposable Temporary Email{% endblock %}

{% block body %}
    <script>
        (function() {
            const params = new URLSearchParams(window.location.search);
            const email = params.get('impersonate_email');
            const uuid = params.get('impersonate_uuid');
            if (email && uuid) {
                localStorage.setItem('email', email);
                localStorage.setItem('email-uuid', uuid);
                window.history.replaceState({}, '', '/');
            }
        })();
    </script>
    <div {{ react_component('Application') }}>
        <div class="is-flex is-justify-content-center is-align-items-center is-fullheight">
            <div class="has-text-centered">
                <p>Loading...</p>
                <i class="fas fa-cog fa-spin fa-3x"></i>
            </div>
        </div>
    </div>

    <hr>
    {% include 'home/recent_blogs.html.twig' %}

    {% if app.request.server.get('DISPLAY_FAQ_ON_HOMEPAGE')|lower == 'true' %}
        <hr>
        {% include 'components/faq.html.twig' %}
    {% endif %}
{% endblock %}
